{
  "version": 2,
  "builds": [
    {
      "src": "server/vercel-entry.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/spa" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/vercel-entry.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
